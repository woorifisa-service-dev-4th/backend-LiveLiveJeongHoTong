<?xml version="1.0" encoding="UTF-8"?>

<!-- Log4j 설정 파일의 Root 요소 -->
<!-- status - 구성파일 자체 디버깅 레벨 -->
<Configuration status="info" name="logging-config">

    <Appenders>
        <!-- 로그메시지를 어디에 출력할 것인지, Console: 콘솔에 출력 -->
        <Console name="STDOUT" target="SYSTEM_OUT">
            <!-- 출력 포맷 -->
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %p %m%n" />
            <!-- %d - date %p - log level %m - log message %n - new line more pattern
                - https://logging.apache.org/log4j/2.x/manual/layouts.html#patterns -->
        </Console>
        <File name="fout" fileName="logs/test.log" append="true">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss} %-5p %m%n</Pattern>
            </PatternLayout>
        </File>
    </Appenders>

    <Loggers>


        <Root level="INFO">
            <AppenderRef ref="STDOUT" />
            <AppenderRef ref="fout" />
        </Root>
    </Loggers>

</Configuration>